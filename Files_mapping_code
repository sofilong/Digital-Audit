#This project is to map the One drive and make and digital inventory on
# current files, current storage, old files that can be deleted, maximize current
#storage capacity, saving cost on extra spend for storage while improving the operational speed on a storage system

import os
import datetime
import csv

#Root path to scan
root_path = r"C:/Users/XXX/OneDrive/"

#Output the mapped data to CSV
file_output ="C:/Users/XXX/OneDrive/Documents/folder_files.csv"

#Set the headers on the folder_files.csv file
header=["folder path","File name","Extension","Size (KB)","Created Date",]

#collect data from mappning folder and files
data=[]

#Loop through the folders and files to map
for folder, subfolders, files in os.walk(root_path):
    for file in files:
        file_path = os.path.join(folder, file)
        try:
            file_size = round(os.path.getsize(file_path)/1024,2)
            file_date= datetime.datetime.fromtimestamp(os.path.getmtime(file_path))
            file_extension=os.path.splitext(file_path)[1]
            data.append([folder,file, file_extension, file_size, file_date.strftime("%m/%d/%Y")])
        except Exception as e:
                #Skip files that prompts for access permissions
                print(f"Skipped {file_path}:{e}")
#Write to the CVS file
with open(file_output, 'w', newline='',encoding="utf-8") as csvfile:
    writer = csv.writer(csvfile)
    writer.writerow(header)
    writer.writerows(data)

print(f"Mapping completed. Data save in {file_output}")
